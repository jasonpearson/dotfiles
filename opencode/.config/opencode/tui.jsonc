{
  "$schema": "https://opencode.ai/tui.json",
  "diff_style": "auto",
  "mouse": false,
  "keybinds": {
    "messages_page_up": "ctrl+u",
    "messages_page_down": "ctrl+d",
    "messages_half_page_up": "ctrl+y",
    "messages_half_page_down": "ctrl+e",
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true,
  },
  "theme": "catppuccin-frappe",
}
