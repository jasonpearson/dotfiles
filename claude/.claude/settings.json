{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": ["Bash(find:*)", "Bash(grep:*)", "Bash(ls:*)"],
    "ask": [
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && tmux rename-window claude || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/bin/tmux-notify.sh await"
          },
          {
            "type": "command",
            "command": "if command -v afplay >/dev/null; then afplay /System/Library/Sounds/Pop.aiff & else printf '\\a'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/bin/tmux-notify.sh await"
          },
          {
            "type": "command",
            "command": "if command -v afplay >/dev/null; then afplay /System/Library/Sounds/Pop.aiff & else printf '\\a'; fi"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/bin/tmux-notify.sh clear"
          },
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && tmux set-window-option automatic-rename on || true"
          }
        ]
      }
    ]
  }
}
